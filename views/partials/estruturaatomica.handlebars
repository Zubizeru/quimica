<!-- Seção Cabeçalho -->
<header class="cabecalho" aria-labelledby="tituloopcao1">
    <i class="fa-solid fa-microscope"></i>
    <h1>Estrutura <span class="cabecalho_titulo_span">Atômica</span></h1>
    <p class="cabecalho_descricao">
        Entenda a estrutura dos átomos e como os elétrons estão distribuídos em níveis e subníveis de energia.
    </p>
</header>
<section class="organizacao_primaria" data-tooltip-source="estruturaatomica">
    <!-- Seção Conversor -->
    <section class="card" aria-labelledby="estruturaatomicaTitulo">
        <div class="estruturaatomica_form">
            <label class="conversor_label" for="estruturaAtomicaInput">Selecione um Elemento</label>
            <div class="busca estruturaatomica_campo" id="conversorFormulaCampo">
                <div class="campo-busca">
                    <i class="fa-solid fa-search campo-busca_icone" aria-hidden="true"></i>
                    <input id="estruturaAtomicaInput" class="campo-busca_input" type="text" inputmode="text"
                        pattern="[A-Za-z0-9()\[\]{}·]*" autocomplete="off" spellcheck="false"
                        placeholder="Buscar por símbolo, nome ou número atômico..."
                        aria-describedby="estruturaAtomicaPreview">
                </div>
                <div class="busca_resultados"></div>
            </div>
            <p class="estruturaatomica_alerta" id="estruturaAtomicaFormulaErro" role="alert" aria-live="polite"></p>
            <p id="estruturaAtomicaPreview" class="estruturaatomica_preview"></p>
        </div>

        <!-- Seção Elementos Comuns para Conversão -->
        <div class="estruturaatomica_secao">
            <div class="estruturaatomica_secao-header">
                <h4>Elementos Comuns</h4>
                <span>Toque para inserir</span>
            </div>
            <div class="estruturaatomica_elementos" id="elementosComuns" aria-live="polite"></div>
        </div>
    </section>

    <section class="estruturaatomica_resultados" aria-label="Detalhes do elemento">
        <section class="card estruturaatomica_card estruturaatomica_card--resumo" aria-label="Resumo do elemento">
            <div class="estruturaatomica_resumo-topo">
                <div class="estruturaatomica_resumo-simbolo" id="estruturaAtomicaResumoSimbolo">--</div>
                <div class="estruturaatomica_resumo-info">
                    <h3 id="estruturaAtomicaResumoNome">Selecione um elemento</h3>
                    <p class="estruturaatomica_resumo-meta" id="estruturaAtomicaResumoCategoria">Categoria: --</p>
                    <p class="estruturaatomica_resumo-meta" id="estruturaAtomicaResumoMassa">Massa: --</p>
                </div>
            </div>
            <div class="estruturaatomica_resumo-dados">
                <div class="estruturaatomica_resumo-item">
                    <span class="estruturaatomica_resumo-numero" id="estruturaAtomicaResumoProtons">-</span>
                    <span class="estruturaatomica_resumo-label">Prótons</span>
                </div>
                <div class="estruturaatomica_resumo-item">
                    <span class="estruturaatomica_resumo-numero" id="estruturaAtomicaResumoNeutrons">-</span>
                    <span class="estruturaatomica_resumo-label">Nêutrons</span>
                </div>
                <div class="estruturaatomica_resumo-item">
                    <span class="estruturaatomica_resumo-numero" id="estruturaAtomicaResumoEletrons">-</span>
                    <span class="estruturaatomica_resumo-label">Elétrons</span>
                </div>
            </div>
        </section>

        <section class="card estruturaatomica_card estruturaatomica_card--config" aria-label="Configuração eletrônica">
            <div class="estruturaatomica_card-header">
                <i class="fa-solid fa-bolt"></i>
                <h3>Configuração Eletrônica</h3>
            </div>
            <div class="estruturaatomica_config-bloco">
                <span class="estruturaatomica_config-label">Notação Abreviada</span>
                <span class="estruturaatomica_config-valor" id="estruturaAtomicaConfigAbreviada">--</span>
            </div>
            <div class="estruturaatomica_config-bloco">
                <span class="estruturaatomica_config-label">Notação Expandida</span>
                <span class="estruturaatomica_config-valor" id="estruturaAtomicaConfigExpandida">--</span>
            </div>
        </section>

        <section class="card estruturaatomica_card estruturaatomica_card--modelo" aria-label="Modelo atômico">
            <div class="estruturaatomica_card-header">
                <i class="fa-solid fa-atom"></i>
                <h3>Modelo Atômico</h3>
            </div>
            <div class="estruturaatomica_modelo-visual" id="estruturaAtomicaModeloVisual">
                <div class="estruturaatomica_orbitas" id="estruturaAtomicaOrbitas"></div>
                <div class="estruturaatomica_nucleo">
                    <span id="estruturaAtomicaNucleoSimbolo">--</span>
                </div>
            </div>
            <div class="estruturaatomica_camadas-lista" id="estruturaAtomicaCamadasLista"></div>
        </section>

        <section class="card estruturaatomica_card estruturaatomica_card--pauling" aria-label="Diagrama de Linus Pauling">
            <div class="estruturaatomica_card-header">
                <i class="fa-solid fa-layer-group"></i>
                <h3>Diagrama de Linus Pauling</h3>
            </div>
            <div class="estruturaatomica_pauling-lista" id="estruturaAtomicaPaulingLista"></div>
            <p class="estruturaatomica_pauling-nota">
                Os elétrons preenchem os orbitais seguindo a regra de Hund: primeiro, um elétron em cada orbital do
                mesmo subnível, depois o segundo elétron é adicionado com spin oposto.
            </p>
        </section>

        <section class="card estruturaatomica_card estruturaatomica_card--valencia" aria-label="Elétrons de valência">
            <div class="estruturaatomica_card-header">
                <i class="fa-solid fa-circle-nodes"></i>
                <h3>Elétrons de Valência</h3>
            </div>
            <div class="estruturaatomica_valencia-topo">
                <div>
                    <span class="estruturaatomica_valencia-label" id="estruturaAtomicaValenciaLabel">Última camada (--)</span>
                    <div class="estruturaatomica_valencia-valor" id="estruturaAtomicaValenciaValor">-</div>
                </div>
                <div class="estruturaatomica_valencia-dots" id="estruturaAtomicaValenciaDots"></div>
            </div>
            <p class="estruturaatomica_valencia-texto" id="estruturaAtomicaValenciaTexto">
                Selecione um elemento para ver os elétrons de valência.
            </p>
        </section>
    </section>

    <!-- Seção Informações sobre estrutura atômica -->
    <section class="card info-estrutura" aria-label="Informações sobre Estrutura Atômica">
        <h3>Conceitos Importantes</h3>
        <section class="info-estrutura_conteudo" aria-label="Conceitos relacionados à estrutura atômica">
            <section class="card_info_organizacao_estrutura" aria-label="">
                <h4>Número Atômico (Z)</h4>
                <p>Quantidade de prótons no núcleo. Define o elemento químico e sua posição na tabela periódica.</p>
            </section>
            <section class="card_info_organizacao_estrutura" aria-label="">
                <h4>Número de Massa (A)</h4>
                <p>Soma de prótons e nêutrons no núcleo. A = Z + N. Diferentes valores de N criam isótopos.</p>
            </section>
            <section class="card_info_organizacao_estrutura">
                <h4>Camadas Eletrônicas</h4>
                <p>Níveis de energia (K, L, M, N...) onde os elétrons orbitam. Cada camada comporta até 2n² elétrons.
                </p>
            </section>
            <section class="card_info_organizacao_estrutura">
                <h4>Subníveis</h4>
                <p>Divisões das camadas: s (2e⁻), p (6e⁻), d (10e⁻), f (14e⁻). Cada subnível tem orbitais específicos.
                </p>
            </section>
            <section class="card_info_organizacao_estrutura">
                <h4>Regra de Hund</h4>
                <p>Elétrons ocupam orbitais vazios antes de emparelhar. Isso minimiza a repulsão eletrônica.</p>
            </section>
            <section class="card_info_organizacao_estrutura">
                <h4>Princípio de Aufbau</h4>
                <p>Elétrons preenchem subníveis em ordem crescente de energia, seguindo o diagrama de Pauling.</p>
            </section>
        </section>

    </section>
</section>
