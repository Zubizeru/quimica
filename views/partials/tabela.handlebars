<!-- Seção Cabeçalho -->
<header class="logotabelaperiodica" aria-labelledby="tituloopcao1">
  <i class="fa-solid fa-table-cells"></i>
  <h1 id="tituloopcao1">Tabela <span class="periodica">Periódica</span></h1>
  <p id="descricao">
    Aqui você pode encontrar informações sobre os elementos da tabela periódica.
  </p>
</header>
<!-- Seção Tabela e Filtros -->
<section class="tabelaefiltro">
  <div class="busca">
    <div class="campo-busca">
      <i class="campo-busca__icone fa-solid fa-magnifying-glass"></i>

      <input class="campo-busca__input" type="text" placeholder="Pesquisar...">

      <button class="campo-busca__limpar" type="button">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <div class="busca__resultados"></div>
  </div>

  <article class="card" aria-live="polite">
    <div class="nomeedescricao">
      <div class="cardnomeelemento">
        <div class="numeroCard"></div>
        <div class="simboloCard"></div>
        <div class="nomeCard">Nome do elemento</div>
        <div class="massaCard"></div>
        <div class="camadasCard"></div>
      </div>
      <div class="descricaodoelemento">
        <p></p>
      </div>
    </div>

    <section class="maisinformacoes" aria-label="Mais informações">
      <div class="maisinformacoes-grid" id="maisinformacoes-grid">
        <div class="info-item massaatomica">
          <span class="info-label">Massa Molar</span>
          <span class="info-value"></span>
        </div>
        <div class="info-item bloco">
          <span class="info-label">Bloco</span>
          <span class="info-value"></span>
        </div>
        <div class="info-item configuracaoeletronica">
          <span class="info-label">Config. Eletrônica</span>
          <span class="info-value"></span>
        </div>
        <div class="info-item eletronegatividade">
          <span class="info-label">Eletronegatividade</span>
          <span class="info-value"></span>
        </div>
        <div class="info-item densidade">
          <span class="info-label">Densidade</span>
          <span class="info-value"></span>
        </div>
        <div class="info-item pontodefusao">
          <span class="info-label">Ponto de Fusão</span>
          <span class="info-value"></span>
        </div>
        <div class="info-item pontodeebulicao">
          <span class="info-label">Ponto de Ebulição</span>
          <span class="info-value"></span>
        </div>
        <div class="info-item periodo">
          <span class="info-label">Período</span>
          <span class="info-value"></span>
        </div>
        <div class="info-item grupo">
          <span class="info-label">Grupo</span>
          <span class="info-value"></span>
        </div>
        <div class="info-item anodedescoberta">
          <span class="info-label">Ano de Descoberta</span>
          <span class="info-value"></span>
        </div>
      </div>
      <div class="minimizaraumentar">
        <button class="icone-aumentar" type="button" aria-expanded="false" aria-controls="maisinformacoes-grid">
          <span class="texto-mais">Mais informações</span>
          <span class="texto-menos">Menos informações</span>
          <i class="fa-solid fa-plus icon-mais"></i>
          <i class="fa-solid fa-minus icon-menos"></i>
        </button>
      </div>
    </section>
  </article>

  <aside class="filtragem" aria-label="Filtrar categorias">
    <div class="itens-filtro" role="list">
      <div id="metal-alcalino" class="filtro-item" role="listitem">
        <p>Metal alcalino</p>
      </div>
      <div id="metal-alcalino-terroso" class="filtro-item" role="listitem">
        <p>Metal alcalino-terroso</p>
      </div>
      <div id="lantanideo" class="filtro-item" role="listitem">
        <p>Lantanídeo</p>
      </div>
      <div id="actinideo" class="filtro-item" role="listitem">
        <p>Actinídeo</p>
      </div>
      <div id="metal-transicao" class="filtro-item" role="listitem">
        <p>Metal de transição</p>
      </div>
      <div id="metal-pos-transicao" class="filtro-item" role="listitem">
        <p>Metal pós-transição</p>
      </div>
      <div id="metaloide" class="filtro-item" role="listitem">
        <p>Metaloides</p>
      </div>
      <div id="nao-metal" class="filtro-item" role="listitem">
        <p>Não metais</p>
      </div>
      <div id="halogenio" class="filtro-item" role="listitem">
        <p>Halogênios</p>
      </div>
      <div id="gas-nobre" class="filtro-item" role="listitem">
        <p>Gás nobre</p>
      </div>
    </div>
  </aside>

  <section class="card tabela-scroll" aria-label="Tabela periódica">
    <div class="tabela-periodica">
      <div class="periodos">
        {{#each periodos}}
        <span class="row-{{row}}" style="grid-row: {{row}};">{{value}}</span>
        {{/each}}
      </div>
      <div class="grupos">
        <span class="placeholder"></span>
        {{#each grupos}}
        <span style="grid-column: {{col}};">{{value}}</span>
        {{/each}}
      </div>
      {{#each elementos}}
      <div
        class="celula-elemento {{extraClass}}{{#if isFblock}} fbloco {{series}}{{/if}} {{cssVar}} row-{{gridRow}} col-{{gridCol}}"
        style="grid-row: {{gridRow}}; grid-column: {{gridCol}};" data-numero="{{numero}}" data-simbolo="{{simbolo}}"
        data-nome="{{nome}}" data-massa="{{massa_molar}}" data-massa-unidade="{{massa_molar_unidade}}"
        data-camadas="{{camadas}}" data-descricao="{{descricao}}" data-categoria="{{category}}" data-bloco="{{bloco}}"
        data-configuracao-eletronica="{{configuracao_eletronica}}" data-eletronegatividade="{{eletronegatividade}}"
        data-densidade="{{densidade}}" data-densidade-unidade="{{densidade_unidade}}" data-ponto-fusao="{{ponto_fusao}}"
        data-ponto-fusao-unidade="{{ponto_fusao_unidade}}" data-ponto-ebulicao="{{ponto_ebulicao}}"
        data-ponto-ebulicao-unidade="{{ponto_ebulicao_unidade}}" data-periodo="{{periodo}}" data-grupo="{{grupo}}"
        data-ano-descoberta="{{ano_descoberta}}">
        <div class="numero">{{numero}}</div>
        <div class="simbolo">{{simbolo}}</div>
        <div class="nome">{{nome}}</div>
      </div>
      {{/each}}
    </div>
  </section>

  <section class="card tabeladepropriedades" aria-label="Tabela de propriedades">
    <section class="eletronegatividadetabela" aria-label="Tabela de eletronegatividade">
      <header>
        <h2>Eletronegatividade</h2>
      </header>
      <p>
        A eletronegatividade é a capacidade que um átomo possui de atrair elétrons
        em uma ligação química. Os valores mais utilizados são os da
        <span class="conceito">Escala de Pauling</span>, proposta pelo químico
        <span class="cientista">Linus Pauling</span>.
      </p>
      <figure class="tabela-pauling">
        <figcaption>
          Elementos mais eletronegativos da tabela periódica (Escala de Pauling)
        </figcaption>
        <ol class="lista-pauling">
          <li class="elemento fluor">
            <span class="simbolo">F</span>
            <span class="nome">Flúor</span>
            <span class="valor">3.98</span>
          </li>
          <li class="elemento oxigenio">
            <span class="simbolo">O</span>
            <span class="nome">Oxigênio</span>
            <span class="valor">3.44</span>
          </li>
          <li class="elemento cloro">
            <span class="simbolo">Cl</span>
            <span class="nome">Cloro</span>
            <span class="valor">3.16</span>
          </li>
          <li class="elemento nitrogenio">
            <span class="simbolo">N</span>
            <span class="nome">Nitrogênio</span>
            <span class="valor">3.04</span>
          </li>
          <li class="elemento bromo">
            <span class="simbolo">Br</span>
            <span class="nome">Bromo</span>
            <span class="valor">2.96</span>
          </li>
          <li class="elemento iodo">
            <span class="simbolo">I</span>
            <span class="nome">Iodo</span>
            <span class="valor">2.66</span>
          </li>
          <li class="elemento enxofre">
            <span class="simbolo">S</span>
            <span class="nome">Enxofre</span>
            <span class="valor">2.58</span>
          </li>
          <li class="elemento carbono">
            <span class="simbolo">C</span>
            <span class="nome">Carbono</span>
            <span class="valor">2.55</span>
          </li>
          <li class="elemento fosforo">
            <span class="simbolo">P</span>
            <span class="nome">Fósforo</span>
            <span class="valor">2.19</span>
          </li>
        </ol>
      </figure>
      <section class="tendencia">
        <h5>Tendência na Tabela Periódica</h5>
        <p>
          A eletronegatividade aumenta da esquerda para a direita ao longo de um período e
          diminui de cima para baixo em um grupo. O Flúor (F) é o elemento mais eletronegativo,
          enquanto o Frâncio (Fr) é o menos eletronegativo.
        </p>
      </section>
    </section>
  </section>
</section>