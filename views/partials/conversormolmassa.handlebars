<!-- Seção Cabeçalho -->
<header class="cabecalho" aria-labelledby="tituloopcao1">
    <i class="fa-solid fa-table-cells"></i>
    <h1>Conversor Mol<span class="cabecalho_titulo_span"> ↔ </span>Massa</h1>
    <p class="cabecalho_descricao">
        Converta facilmente entre quantidade de matéria (mol) e massa usando a massa molar dos compostos.
    </p>
</header>
<section class="organizacao_primaria" data-tooltip-source="conversormolmassa">
    <!-- Seção Conversor -->
    <section class="card" aria-labelledby="conversorMolMassaTitulo">
        <div class="conversormolmassa_form">
            <label class="conversor_label" for="conversorFormulaInput">Fórmula da Substância</label>
            <div class="busca conversormolmassa_campo" id="conversorFormulaCampo">
                <div class="campo-busca">
                    <i class="fa-solid fa-flask campo-busca_icone" aria-hidden="true"></i>
                    <input id="conversorFormulaInput" class="campo-busca_input" type="text" inputmode="text"
                        pattern="[A-Za-z0-9()\[\]{}·]*" autocomplete="off" spellcheck="false"
                        placeholder="Ex: H2O, CO2, Ca(OH)2" aria-describedby="conversorFormulaPreview">
                    <button type="button" class="campo-busca_limpar" id="conversorLimparFormula" aria-label="Limpar fórmula">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            </div>
            <div class="conversormolmassa_preview" id="conversorFormulaPreview">Digite uma fórmula</div>
            <p class="conversormolmassa_alerta" id="conversorFormulaErro" role="alert" aria-live="polite"></p>
        </div>

        <div class="conversormolmassa_form">
            <label class="conversor_label" id="conversorValorLabel" for="conversorValorInput">Quantidade de matéria (mol)</label>
            <div class="busca conversormolmassa_campo" id="conversorValorCampo">
                <div class="campo-busca">
                    <i class="fa-solid fa-scale-balanced campo-busca_icone" aria-hidden="true"></i>
                    <input id="conversorValorInput" class="campo-busca_input" type="text" inputmode="decimal"
                        autocomplete="off" spellcheck="false" placeholder="Ex: 2,5" aria-describedby="conversorValorAjuda">
                    <button type="button" class="campo-busca_limpar" id="conversorLimparValor" aria-label="Limpar valor">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            </div>
            <div class="conversormolmassa_hint" id="conversorValorAjuda">Digite a quantidade em mol para converter em gramas.</div>
            <p class="conversormolmassa_alerta" id="conversorValorErro" role="alert" aria-live="polite"></p>
        </div>

        <!-- Seção Elementos Comuns para Conversão -->
        <div class="conversormolmassa_secao">
            <div class="conversormolmassa_secao-header">
                <h4>Elementos Comuns</h4>
                <span>Toque para inserir</span>
            </div>
            <div class="conversormolmassa_elementos" id="elementosComuns" aria-live="polite"></div>
        </div>

        <!-- Seção Compostos Comuns para Conversão -->
        <div class="conversormolmassa_secao">
            <div class="conversormolmassa_secao-header">
                <h4>Compostos Comuns</h4>
                <span>Toque para inserir</span>
            </div>
            <div class="conversormolmassa_compostos-grid" id="compostosComuns" aria-live="polite"></div>
        </div>

        <!-- Seção Teclado Químico para Conversão -->
        <div class="conversormolmassa_secao">
            <div class="conversormolmassa_secao-header">
                <h4>Teclado Químico</h4>
                <span>Parênteses, números e hidratação</span>
            </div>
            <div class="conversormolmassa_teclado" id="tecladoQuimico"></div>
        </div>

        <!-- Escolher Modo de Conversão -->
        <div class="conversormolmassa_secao">
            <div class="conversormolmassa_secao-header">
                <h4>Modo de Conversão</h4>
                <span>Selecione o tipo de conversão</span>
            </div>
            <div class="selecaoconversao" role="radiogroup" aria-label="Escolha o modo de conversão">
                <button class="modo-botao molparamassa modo-ativo" id="molParaMassa" type="button" role="radio" aria-checked="true">
                    <p>Mol para massa</p>
                    <span>mol → g</span>
                </button>
                <button class="alternar" id="alternarConversao" type="button" aria-label="Alternar modo">
                    <i class="fa-solid fa-exchange-alt"></i>
                </button>
                <button class="modo-botao massaparamol" id="massaParaMol" type="button" role="radio" aria-checked="false">
                    <p>Massa para Mol</p>
                    <span>g → mol</span>
                </button>
            </div>
        </div>

        <button class="resultado_botao" id="convertermolmassa" type="button">Converter</button>

        <div class="conversormolmassa_resultado" id="conversorResultado" hidden>
            <div class="conversormolmassa_resumo">
                <p class="conversormolmassa_resumo-label" id="resultadoModo">Mol para massa</p>
                <div class="conversormolmassa_resumo-formula" id="resultadoFormula">-</div>
                <div class="conversormolmassa_resumo-valor" id="resultadoValor">-</div>
                <div class="conversormolmassa_resumo-detalhe" id="resultadoDetalhe">-</div>
            </div>

            <div class="conversormolmassa_blocos">
                <div class="conversormolmassa_bloco">
                    <span class="conversormolmassa_bloco-label">Massa molar usada</span>
                    <strong class="conversormolmassa_bloco-valor" id="resultadoMassaMolar">-</strong>
                </div>
                <div class="conversormolmassa_bloco">
                    <span class="conversormolmassa_bloco-label">Relação aplicada</span>
                    <strong class="conversormolmassa_bloco-valor" id="resultadoRelacao">-</strong>
                </div>
            </div>

            <div class="conversormolmassa_passos">
                <h4>Passo a passo</h4>
                <div class="conversormolmassa_passos-lista" id="resultadoPassos"></div>
            </div>
        </div>
    </section>

    <!-- Seção Informações sobre o Mol -->
    <section class="card info-conversao" aria-label="Informações sobre Conversão de Massa e Massa Molar">
        <section class="card_info_organizacao" aria-label="">
            <header>
                <h2>O que é o Mol?</h2>
            </header>
            <p class="card_info_escrita">
                O <span>mol</span> é a unidade de medida do <span class="tooltip-trigger"
                    data-tooltip-key="sistema-internacional" tabindex="0">Sistema Internacional (SI)</span> para
                quantidade de matéria. Um
                mol contém
                exatamente <span>6,022 × 10²³</span> entidades elementares (<span class="tooltip-trigger"
                    data-tooltip-key="constante-de-avogadro" tabindex="0">constante de Avogadro</span>), sejam átomos,
                moléculas, íons ou
                outras partículas.

                A relação entre massa, mol e massa molar é fundamental na química: conhecendo dois desses valores, é
                possível calcular o terceiro. Essa conversão é essencial para cálculos estequiométricos e preparação de
                soluções.

                <span>Exemplo:</span> Para obter 36 g de água (H₂O), precisamos de 2 mol, pois a massa molar da água é
                18 g/mol (36 ÷
                18 = 2).
            </p>
        </section>
    </section>
</section>
